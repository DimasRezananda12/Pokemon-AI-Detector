apps/api/data/community_exports/
apps/api/data/governance_exports/
apps/api/data/quality_reports/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Python cache and test artifacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.pytest-tmp/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# Node dependencies and build output
node_modules/
apps/web/node_modules/
.next/
.next-*/
apps/web/.next/
apps/web/.next-*/
apps/web/out/
apps/web/coverage/
*.tsbuildinfo

# Editor and OS local files
.vscode/
.idea/
.DS_Store
Thumbs.db

